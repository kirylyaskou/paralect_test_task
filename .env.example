# Supabase (server-only -- NO NEXT_PUBLIC_ prefix for service_role)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Supabase public (for Realtime and Storage -- client-side)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# OpenRouter (LLM provider -- get key at https://openrouter.ai/settings/keys)
OPENROUTER_API_KEY=your-openrouter-api-key

# Session (generate with: openssl rand -base64 32)
SESSION_SECRET=your-session-secret-min-32-chars
